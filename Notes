<script>
"use strict";
 
const STORAGE_KEY   = "folio_notes_v1";
const THEME_KEY     = "folio_theme";
const MAX_PREVIEW   = 180;
const TOAST_MS      = 2800;
 
/* ── State ── */
const state = {
  notes: [], filter: "", sort: "newest",
  selectedColor: "default", pendingDeleteId: null, view: "grid",
};
 
/* ── DOM cache ── */
const $ = id => document.getElementById(id);
const el = {
  titleInput:   $("noteTitle"),    contentInput: $("noteContent"),
  titleCount:   $("titleCount"),   contentCount: $("contentCount"),
  saveBtn:      $("saveBtn"),      errorMsg:     $("errorMsg"),
  search:       $("searchInput"),  sort:         $("sortSelect"),
  themeBtn:     $("themeToggle"),  container:    $("notesContainer"),
  noteCount:    $("noteCount"),    wordCount:    $("wordCount"),
  boardTitle:   $("boardTitle"),   toastStack:   $("toastStack"),
  modal:        $("modal"),        cancelDelete: $("cancelDelete"),
  confirmDelete:$("confirmDelete"),gridView:     $("gridView"),
  listView:     $("listView"),     dots:         document.querySelectorAll(".dot"),
};
 
/* ── Persistence ── */
function persist() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state.notes)); }
  catch { showToast("Storage full!", "error"); }
}
function hydrate() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    state.notes = raw ? JSON.parse(raw) : [];
  } catch { state.notes = []; }
}
 
/* ── CRUD ── */
function generateId() {
  return (typeof crypto !== "undefined" && crypto.randomUUID)
    ? crypto.randomUUID()
    : `${Date.now()}-${Math.random().toString(36).slice(2,7)}`;
}
 
function createNote() {
  const title   = el.titleInput.value.trim();
  const content = el.contentInput.value.trim();
  if (!title && !content) { setError("Both title and content are required."); shake(el.saveBtn); return; }
  if (!title)   { setError("Title is required.");   shake(el.titleInput);   return; }
  if (!content) { setError("Content is required."); shake(el.contentInput); return; }
 
  state.notes.unshift({
    id: generateId(), title, content,
    color: state.selectedColor,
    createdAt: new Date().toISOString(),
  });
  persist();
  el.titleInput.value = ""; el.contentInput.value = "";
  updateCounters(); setError(""); setColor("default");
  render();
  showToast("Note saved ✓");
  requestAnimationFrame(() => {
    const first = el.container.firstElementChild;
    if (first) { first.style.outline = "2px solid var(--text)"; setTimeout(() => first.style.outline = "", 1200); }
  });
}
 
function requestDelete(id) { state.pendingDeleteId = id; openModal(); }
 
function commitDelete() {
  const card = el.container.querySelector(`[data-id="${state.pendingDeleteId}"]`);
  const finish = () => {
    state.notes = state.notes.filter(n => n.id !== state.pendingDeleteId);
    state.pendingDeleteId = null;
    persist(); render(); closeModal();
    showToast("Note deleted", "info");
  };
  if (card) {
    card.style.transition = "opacity .25s, transform .25s";
    card.style.opacity = "0"; card.style.transform = "scale(.95)";
    setTimeout(finish, 260);
  } else { finish(); }
}
 
/* ── Derived ── */
function getVisible() {
  let list = [...state.notes];
  const q = state.filter.toLowerCase();
  if (q) list = list.filter(n => n.title.toLowerCase().includes(q) || n.content.toLowerCase().includes(q));
  if (state.sort === "oldest") list.sort((a,b) => new Date(a.createdAt) - new Date(b.createdAt));
  else if (state.sort === "alpha") list.sort((a,b) => a.title.localeCompare(b.title));
  else list.sort((a,b) => new Date(b.createdAt) - new Date(a.createdAt));
  return list;
}
 
/* ── Render ── */
function render() {
  const visible = getVisible();
  el.boardTitle.textContent = state.filter
    ? `"${state.filter}" — ${visible.length} result${visible.length === 1 ? "" : "s"}`
    : "All Notes";
  const total = state.notes.length;
  const totalWords = state.notes.reduce((a, n) => a + countWords(n.content), 0);
  el.noteCount.textContent = `${total} note${total === 1 ? "" : "s"}`;
  el.wordCount.textContent  = `${totalWords.toLocaleString()} word${totalWords === 1 ? "" : "s"}`;
  el.container.className = "notes-grid" + (state.view === "list" ? " list-mode" : "");
 
  if (visible.length === 0) {
    el.container.innerHTML = `
      <div class="empty-state">
        <span class="empty-icon">✦</span>
        <p class="empty-msg">${state.filter ? "No notes match your search." : "Your notebook is empty."}</p>
        <p class="empty-sub">${state.filter ? "Try a different query." : "Write your first note →"}</p>
      </div>`;
    return;
  }
 
  const frag = document.createDocumentFragment();
  visible.forEach((note, i) => frag.appendChild(buildCard(note, i)));
  el.container.innerHTML = "";
  el.container.appendChild(frag);
}
 
function buildCard(note, i) {
  const art = document.createElement("article");
  art.className = "note-card";
  art.dataset.id = note.id;
  art.dataset.color = note.color || "default";
  art.style.animationDelay = `${i * 40}ms`;
  art.innerHTML = `
    <h3 class="card-title">${escapeHTML(note.title)}</h3>
    <p  class="card-content">${escapeHTML(truncate(note.content, MAX_PREVIEW))}</p>
    <div class="card-footer">
      <time class="card-date" datetime="${note.createdAt}">${formatDate(note.createdAt)}</time>
      <div class="card-actions">
        <button class="card-btn danger js-del" aria-label="Delete note">DELETE</button>
      </div>
    </div>`;
  art.querySelector(".js-del").addEventListener("click", e => { e.stopPropagation(); requestDelete(note.id); });
  return art;
}
 
/* ── Theme ── */
function applyTheme(t) { document.documentElement.setAttribute("data-theme", t); localStorage.setItem(THEME_KEY, t); }
function toggleTheme() { applyTheme(document.documentElement.getAttribute("data-theme") === "dark" ? "light" : "dark"); }
 
/* ── Color ── */
function setColor(c) {
  state.selectedColor = c;
  el.dots.forEach(d => d.classList.toggle("active", d.dataset.color === c));
}
 
/* ── Modal ── */
function openModal()  { el.modal.hidden = false; el.confirmDelete.focus(); }
function closeModal() { el.modal.hidden = true; state.pendingDeleteId = null; }
 
/* ── Toast ── */
function showToast(msg, type = "success") {
  const t = document.createElement("div");
  t.className = `toast ${type}`; t.setAttribute("role","status"); t.textContent = msg;
  el.toastStack.appendChild(t);
  setTimeout(() => t.remove(), TOAST_MS);
}
 
/* ── Helpers ── */
function escapeHTML(s) { const d = document.createElement("div"); d.textContent = String(s); return d.innerHTML; }
function truncate(t, n) { return t.length > n ? t.slice(0, n).trimEnd() + "…" : t; }
function countWords(t)  { return t.trim() ? t.trim().split(/\s+/).length : 0; }
function setError(m)    { el.errorMsg.textContent = m; }
function formatDate(iso) {
  const d = new Date(iso), now = new Date();
  const diff = Math.floor((now - d) / 86400000);
  if (diff === 0) return "Today, " + d.toLocaleTimeString([], {hour:"2-digit", minute:"2-digit"});
  if (diff === 1) return "Yesterday";
  if (diff < 7)  return d.toLocaleDateString([], {weekday:"long"});
  return d.toLocaleDateString([], {month:"short", day:"numeric", year:"numeric"});
}
function updateCounters() {
  const tl = el.titleInput.value.length, cl = el.contentInput.value.length;
  el.titleCount.textContent = tl; el.contentCount.textContent = cl;
  el.titleInput.closest(".field-group").querySelector(".char-counter").classList.toggle("warn", tl > 50);
  el.contentInput.closest(".field-group").querySelector(".char-counter").classList.toggle("warn", cl > 700);
}
function shake(t) {
  t.animate([
    {transform:"translateX(0)"},{transform:"translateX(-6px)"},
    {transform:"translateX(6px)"},{transform:"translateX(-4px)"},{transform:"translateX(0)"}
  ], {duration:350, easing:"ease-out"});
}
 
/* ── Events ── */
el.saveBtn.addEventListener("click", createNote);
el.titleInput.addEventListener("keydown",   e => { if (e.key === "Enter") { e.preventDefault(); el.contentInput.focus(); } });
el.contentInput.addEventListener("keydown", e => { if (e.key === "Enter" && (e.ctrlKey || e.metaKey)) createNote(); });
el.titleInput.addEventListener("input",   updateCounters);
el.contentInput.addEventListener("input", updateCounters);
[el.titleInput, el.contentInput].forEach(i => i.addEventListener("input", () => setError("")));
el.search.addEventListener("input",  e => { state.filter = e.target.value.trim(); render(); });
el.sort.addEventListener("change",   e => { state.sort   = e.target.value;        render(); });
el.themeBtn.addEventListener("click", toggleTheme);
el.dots.forEach(d => d.addEventListener("click", () => setColor(d.dataset.color)));
el.gridView.addEventListener("click", () => { state.view = "grid"; el.gridView.classList.add("active"); el.listView.classList.remove("active"); render(); });
el.listView.addEventListener("click", () => { state.view = "list"; el.listView.classList.add("active"); el.gridView.classList.remove("active"); render(); });
el.cancelDelete.addEventListener("click",  closeModal);
el.confirmDelete.addEventListener("click", commitDelete);
el.modal.addEventListener("click", e => { if (e.target === el.modal) closeModal(); });
document.addEventListener("keydown", e => { if (e.key === "Escape" && !el.modal.hidden) closeModal(); });
 
/* ── Init ── */
(() => {
  applyTheme(localStorage.getItem(THEME_KEY) || "light");
  hydrate(); render();
  if (window.innerWidth > 900) el.titleInput.focus();
})();
</script>
</body>
</html>
